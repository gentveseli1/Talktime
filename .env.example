POSTGRES_USER=chat
POSTGRES_PASSWORD=chat
POSTGRES_DB=chat

# Streaming-replication role used by postgres-replica to connect to
# postgres-primary. Created automatically by infra/postgres/primary-init.sh
# the first time the primary is initialised.
REPLICATION_USER=replicator
REPLICATION_PASSWORD=replicator-pw

JWT_SECRET=replace-me-with-long-random-string
